DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=backend.config.prod

# PostgreSQL Database Configuration
POSTGRES_DB=momodu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL for SQLAlchemy (FastAPI)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/momodu

# Redis Configuration (Celery Broker) - Use Redis Cloud free tier for production
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# External Services Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_APPROVAL_CHAT_ID=your-telegram-chat-id-for-approvals

# LinkedIn Integration
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# JWT Settings (FastAPI)
SECRET_KEY=your-jwt-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
